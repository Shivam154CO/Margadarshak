# ✅ CRITICAL FIX: Safely convert numeric columns
def safe_numeric_conversion(series):
    """Safely convert series to numeric, handling all edge cases"""
    if series is None or len(series) == 0:
        return pd.Series([0] * len(df))
    
    # Convert to string first
    str_series = series.astype(str)
    
    # Replace common non-numeric values
    str_series = str_series.replace(['N/A', 'NA', 'NaN', 'nan', '', ' ', 'null', 'NULL', 'None'], '0')
    
    # Remove any non-numeric characters (except decimal points and negative signs)
    str_series = str_series.str.replace(r'[^\d\.\-]', '', regex=True)
    
    # Handle empty strings
    str_series = str_series.replace('', '0')
    
    # Convert to numeric
    numeric_series = pd.to_numeric(str_series, errors='coerce')
    
    # Fill NaN with 0
    numeric_series = numeric_series.fillna(0)
    
    return numeric_series

