# ✅ Enhanced helper function to predict fit based on both score and rank
def predict_fit_comprehensive(user_score, user_rank, college_cutoff_rank, college_cutoff_percentile):
    """Predict fit based on both score and rank comparison"""
    predictions = []
    reasons = []
    
    # Check if we have valid data
    if (not user_score or user_score <= 0) and (not user_rank or user_rank <= 0):
        return "Unknown Fit", "User score and rank not provided"
    
    if college_cutoff_rank <= 0 and college_cutoff_percentile <= 0:
        return "Unknown Fit", "College cutoff data unavailable"
    
    # 1. Predict based on RANK (if available)
    if user_rank and user_rank > 0 and college_cutoff_rank > 0:
        rank_diff = college_cutoff_rank - user_rank  # Positive = user has better rank
        
        if rank_diff >= 1000:
            predictions.append("Best Fit")
            reasons.append(f"Your rank ({user_rank:,}) is significantly better than cutoff rank ({college_cutoff_rank:,})")
        elif rank_diff >= 100:
            predictions.append("Good Fit")
            reasons.append(f"Your rank ({user_rank:,}) is better than cutoff rank ({college_cutoff_rank:,})")
        elif rank_diff >= -500:
            predictions.append("Stretch")
            reasons.append(f"Your rank ({user_rank:,}) is close to cutoff rank ({college_cutoff_rank:,})")
        else:
            predictions.append("Unlikely Fit")
            reasons.append(f"Your rank ({user_rank:,}) is lower than cutoff rank ({college_cutoff_rank:,})")
    
    # 2. Predict based on SCORE/PERCENTILE (if available)
    if user_score and user_score > 0 and college_cutoff_percentile > 0:
        score_diff = user_score - college_cutoff_percentile  # Positive = user has better score
        
        if score_diff >= 5:
            predictions.append("Best Fit")
            reasons.append(f"Your score ({user_score:.2f}%) is significantly higher than cutoff ({college_cutoff_percentile:.2f}%)")
        elif score_diff >= 2:
            predictions.append("Good Fit")
            reasons.append(f"Your score ({user_score:.2f}%) is higher than cutoff ({college_cutoff_percentile:.2f}%)")
        elif score_diff >= -2:
            predictions.append("Stretch")
            reasons.append(f"Your score ({user_score:.2f}%) is close to cutoff ({college_cutoff_percentile:.2f}%)")
        else:
            predictions.append("Unlikely Fit")
            reasons.append(f"Your score ({user_score:.2f}%) is lower than cutoff ({college_cutoff_percentile:.2f}%)")
    
    # If we have predictions, return the best one
    if predictions:
        fit_order = {"Best Fit": 0, "Good Fit": 1, "Stretch": 2, "Unlikely Fit": 3}
        best_fit = min(predictions, key=lambda x: fit_order.get(x, 4))
        
        # Get corresponding reason
        best_index = predictions.index(best_fit)
        reason = reasons[best_index]
        
        return best_fit, reason
    
    return "Unknown Fit", "Insufficient data for prediction"

# ✅ Function to calculate match score (0-100)
def calculate_match_score(user_score, user_rank, cutoff_rank, cutoff_percentile):
    """Calculate a comprehensive match score (0-100) based on user's metrics vs cutoff"""
    total_score = 0
    factors = 0
    
    # Rank factor (50 points max)
    if user_rank and cutoff_rank > 0:
        if user_rank <= 0:
            rank_factor = 0
        elif user_rank <= (cutoff_rank * 0.5):  # Much better rank
            rank_factor = 50
        elif user_rank <= (cutoff_rank * 0.8):  # Better rank
            rank_factor = 40
        elif user_rank <= cutoff_rank:  # Equal or slightly better
            rank_factor = 30
        elif user_rank <= (cutoff_rank * 1.2):  # Within 20% of cutoff
            rank_factor = 20
        elif user_rank <= (cutoff_rank * 1.5):  # Within 50% of cutoff
            rank_factor = 10
        else:
            rank_factor = 0
        
        total_score += rank_factor
        factors += 1
    
    # Score/Percentile factor (50 points max)
    if user_score and cutoff_percentile > 0:
        if user_score <= 0:
            score_factor = 0
        elif user_score >= (cutoff_percentile + 10):  # Much better score
            score_factor = 50
        elif user_score >= (cutoff_percentile + 5):  # Better score
            score_factor = 40
        elif user_score >= cutoff_percentile:  # Equal or slightly better
            score_factor = 30
        elif user_score >= (cutoff_percentile - 5):  # Within 5% of cutoff
            score_factor = 20
        elif user_score >= (cutoff_percentile - 10):  # Within 10% of cutoff
            score_factor = 10
        else:
            score_factor = 0
        
        total_score += score_factor
        factors += 1
    
    # If we have no factors to calculate, return neutral score
    if factors == 0:
        return 50
    
    # Normalize to 0-100 scale
    max_possible = 50 * factors
    match_score = (total_score / max_possible) * 100
    
    return round(match_score, 1)

# ✅ Function to calculate admission chance percentage
def calculate_admission_chance(user_score, user_rank, cutoff_rank, cutoff_percentile):
    """Calculate admission chance percentage (0-100%)"""
    match_score = calculate_match_score(user_score, user_rank, cutoff_rank, cutoff_percentile)
    
    # Convert match score to admission chance
    if match_score >= 90:
        return 95
    elif match_score >= 80:
        return 85
    elif match_score >= 70:
        return 75
    elif match_score >= 60:
        return 65
    elif match_score >= 50:
        return 55
    elif match_score >= 40:
        return 45
    elif match_score >= 30:
        return 35
    elif match_score >= 20:
        return 25
    elif match_score >= 10:
        return 15
    else:
        return 5

# ✅ Function to safely extract numeric values
def safe_extract(value, default=0, data_type=float):
    """Safely extract and convert values from dataframe"""
    try:
        if pd.isna(value) or value is None:
            return default
        
        # Convert to string first
        str_value = str(value).strip()
        
        # Handle common non-numeric values
        if str_value in ['N/A', 'NA', 'NaN', 'nan', '', ' ', 'null', 'NULL']:
            return default
        
        # Remove non-numeric characters
        str_value = ''.join(c for c in str_value if c.isdigit() or c == '.' or c == '-')
        
        if not str_value or str_value == '-' or str_value == '.':
            return default
        
        # Convert to appropriate type
        if data_type == int:
            return int(float(str_value))
        else:
            return float(str_value)
    except Exception as e:
        print(f"⚠️ Error extracting value '{value}': {str(e)}")
        return default

