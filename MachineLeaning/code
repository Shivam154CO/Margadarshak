                filtered_df = filtered_df[city_mask].copy()
                print(f"📊 After city filter: {len(filtered_df)} records")
            else:
                print("⚠️ No city matches, showing all cities")
        
        # ✅ STEP 5: Filter by placement rate
        if 'placement_rate' in filtered_df.columns and min_placement_float > 0 and len(filtered_df) > 0:
            placement_mask = filtered_df['placement_rate'] >= min_placement_float
            filtered_df = filtered_df[placement_mask].copy()
            print(f"📊 After placement filter: {len(filtered_df)} records")
        
        # Ensure we have data
        if len(filtered_df) == 0:
            print("\n⚠️ No records after all filters!")
            print("🔍 Returning sample data for debugging...")
            
            # Get sample data for debugging
            if 'branch_norm' in df.columns:
                sample_df = df[df['branch_norm'].isin(preferred_branches_clean)].head(50).copy()
            else:
                sample_df = df.head(50).copy()
            
            filtered_df = sample_df
            print(f"📊 Showing {len(filtered_df)} sample records")
        
        print(f"\n🎯 Final dataset for processing: {len(filtered_df)} records")
        
        # ✅ STEP 6: Process each record
        frontend_colleges = []
        processed_count = 0
        error_count = 0
        
        for idx, row in filtered_df.iterrows():
            try:
                # Extract data with safe conversion
                cutoff_rank = safe_extract(row.get('cutoff_rank', 0), 0, int)
                cutoff_percentile = safe_extract(row.get('cutoff_percentile', 0), 0.0, float)
                seats = safe_extract(row.get('seats', 0), 0, int)
                fees = safe_extract(row.get('fees', 0), 0.0, float)
                total_intake = safe_extract(row.get('total_intake', 0), 0, int)
                
                # Get string values
                college_name = str(row.get('college_name', 'Unknown College')).strip()
                branch_name = str(row.get('branch_name', 'N/A')).strip()
                college_category = str(row.get('category', 'N/A')).strip()
                city = str(row.get('city', 'N/A')).strip()
                
                # Debug print for first few records
                if processed_count < 5:
                    print(f"🏫 Processing [{processed_count+1}]: {college_name[:30]}... - {branch_name[:20]}...")
                    print(f"   Category: {college_category}, City: {city}")
                    print(f"   Cutoff Rank: {cutoff_rank}, Cutoff %: {cutoff_percentile:.2f}")
                    print(f"   Fees: ₹{fees:,.0f}, Seats: {seats}")
                
                # Calculate predictions
                fit, fit_reason = predict_fit_comprehensive(
                    user_score_float, user_rank_int, cutoff_rank, cutoff_percentile
                )
                
                match_score = calculate_match_score(
                    user_score_float, user_rank_int, cutoff_rank, cutoff_percentile
                )
                
                admission_chance = calculate_admission_chance(
                    user_score_float, user_rank_int, cutoff_rank, cutoff_percentile
                )
                
                # Only include if match score is reasonable
                if match_score >= 10 or len(frontend_colleges) < 20:  # Always include at least 20
                    # Create college object
                    college_obj = {
                        # Basic info
                        'college_code': str(row.get('college_code', '')),
                        'college_name': college_name,
                        'short_name': str(row.get('short_name', '')),
                        'city': city,
                        
                        # Branch info
                        'branch': branch_name,
                        'branch_name': branch_name,
                        'branch_code': str(row.get('branch_code', '')),
                        'branch_specific': True,
                        
                        # Financial info
                        'fees': fees,
                        'hostel_fees': safe_extract(row.get('hostel_fees', 0), 0.0, float),
                        'bus_fees': safe_extract(row.get('bus_fees', 0), 0.0, float),
                        
                        # Academic info
                        'placement_rate': safe_extract(row.get('placement_rate', 0), 0.0, float),
                        'average_package_lpa': safe_extract(row.get('average_package_lpa', 0), 0.0, float),
                        'highest_package_lpa': safe_extract(row.get('highest_package_lpa', 0), 0.0, float),
                        'internship_rate': safe_extract(row.get('internship_rate', 0), 0.0, float),
                        'foreign_offers': safe_extract(row.get('foreign_offers', 0), 0, int),
                        
                        # Cutoff info
                        'cutoff_score': cutoff_rank,
                        'cutoff_rank': cutoff_rank,
                        'cutoff_percentile': cutoff_percentile,
                        
                        # Capacity info
                        'total_intake': total_intake,
                        'seats': seats,
                        
                        # College details
                        'autonomy_status': str(row.get('autonomy_status', 'N/A')),
                        'hostel_available': str(row.get('hostel_available', 'N/A')),
                        'image': str(row.get('image_url', '')),
                        'category': college_category,
                        'university': str(row.get('university', 'N/A')),
                        'established_year': safe_extract(row.get('established_year', 0), 0, int),
                        'accreditation': str(row.get('accreditation', 'N/A')),
                        'district': str(row.get('district', 'N/A')),
                        'region': str(row.get('region', 'N/A')),
                        'degree_type': str(row.get('degree_type', 'N/A')),
                        'duration_years': safe_extract(row.get('duration_years', 0), 0, int),
                        
                        # Facilities
                        'top_recruiters': str(row.get('top_recruiters', 'N/A')),
                        'hostel_type': str(row.get('hostel_type', 'N/A')),
                        'labs_count': safe_extract(row.get('labs_count', 0), 0, int),
                        'wifi_campus': str(row.get('wifi_campus', 'N/A')),
                        'transport_facility': str(row.get('transport_facility', 'N/A')),
                        'medical_facility': str(row.get('medical_facility', 'N/A')),
                        'hostel_capacity': safe_extract(row.get('hostel_capacity', 0), 0, int),
                        
                        # Contact info
                        'logo_url': str(row.get('logo_url', '')),
                        'contact_email': str(row.get('contact_email', 'N/A')),
                        'contact_phone': str(row.get('contact_phone', 'N/A')),
                        'website_url': str(row.get('website_url', 'N/A')),
                        
                        # Prediction results
                        'fit': fit,
                        'fit_reason': fit_reason,
                        'match_score': match_score,
                        'match_percentage': f"{match_score:.1f}%",
                        'admission_chance': admission_chance,
                        'admission_chance_percentage': f"{admission_chance}%",
                        'user_score': user_score_float,
                        'user_rank': user_rank_int,
                        
                        # Display fields
                        'display_fees': f"₹{fees:,.0f}/year",
                        'display_seats': f"{seats:,} seats",
                        'display_total_intake': f"{total_intake:,} total intake",
                        'display_cutoff': f"Rank: {cutoff_rank:,}" if cutoff_rank > 0 else f"Percentile: {cutoff_percentile:.1f}%",
                        'display_cutoff_full': f"Rank: {cutoff_rank:,} | Percentile: {cutoff_percentile:.1f}%",
                        'display_placement': f"{safe_extract(row.get('placement_rate', 0), 0.0, float):.1f}%",
                        'display_avg_package': f"₹{safe_extract(row.get('average_package_lpa', 0), 0.0, float):,.1f}L",
                        'display_high_package': f"₹{safe_extract(row.get('highest_package_lpa', 0), 0.0, float):,.1f}L",
                        'display_info': f"{branch_name} | {city}",
                        'display_stats': f"Seats: {seats:,} | Cutoff: {cutoff_rank if cutoff_rank > 0 else cutoff_percentile:.1f}%"
                    }
                    
                    frontend_colleges.append(college_obj)
                    processed_count += 1
                
            except Exception as e:
                error_count += 1
                print(f"⚠️ Error processing row {idx}: {str(e)}")
                continue
        
        print(f"\n✅ Processing complete:")
        print(f"   • Successfully processed: {processed_count}")
        print(f"   • Errors encountered: {error_count}")
        print(f"   • Total records available: {len(filtered_df)}")
        
        # Sort results
        fit_order = {"Best Fit": 0, "Good Fit": 1, "Stretch": 2, "Unlikely Fit": 3, "Unknown Fit": 4}
        frontend_colleges.sort(key=lambda x: (
            fit_order.get(x.get('fit', 'Unknown Fit'), 5),
            -x.get('match_score', 0),
            -x.get('placement_rate', 0),
            x.get('fees', 0)
        ))
        
        # Apply limit
        frontend_colleges = frontend_colleges[:limit]
        
        print(f"🎯 Returning {len(frontend_colleges)} college-branch combinations")
        print("="*60)
        
        # Calculate statistics
        best_fit_count = len([c for c in frontend_colleges if c.get('fit') == 'Best Fit'])
        good_fit_count = len([c for c in frontend_colleges if c.get('fit') == 'Good Fit'])
        stretch_count = len([c for c in frontend_colleges if c.get('fit') == 'Stretch'])
        unlikely_count = len([c for c in frontend_colleges if c.get('fit') == 'Unlikely Fit'])
        
        return jsonify({
            "total": len(frontend_colleges),
            "statistics": {
                "safe_bets": best_fit_count,
                "target_colleges": good_fit_count,
                "risky_options": stretch_count + unlikely_count,
                "processed": processed_count,
                "errors": error_count,
                "filtered_records": len(filtered_df)
            },
            "user_profile": {
                "user_score": user_score_float,
                "user_rank": user_rank_int,
                "user_category": user_category,
                "preferred_branches": preferred_branches,
                "preferred_cities": preferred_cities,
                "max_fees": max_fees_float,
                "min_placement": min_placement_float
            },
            "debug_info": {
                "initial_records": len(df),
                "branch_filtered": len(filtered_df),
                "final_results": len(frontend_colleges),
                "match_score_range": f"{min([c.get('match_score', 0) for c in frontend_colleges]):.1f}-{max([c.get('match_score', 0) for c in frontend_colleges]):.1f}" if frontend_colleges else "N/A"
            },
            "colleges": frontend_colleges
        })
        
    except Exception as e:
        print(f"❌ Error in /predict_admission: {str(e)}")
        traceback.print_exc()
        return jsonify({
            "error": str(e),
            "traceback": traceback.format_exc()
        }), 500

